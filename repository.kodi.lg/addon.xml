<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.kodi.lg" version="1.0.9" name="Kodi LG Repository" provider-name="Unrefundable">
    <requires>
        <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Kodi LG Repository">
        <dir>
            <info compressed="false">https://unrefundable.github.io/kodi-lg/addons.xml</info>
            <checksum>https://unrefundable.github.io/kodi-lg/addons.xml.md5</checksum>
            <datadir zip="true">https://unrefundable.github.io/kodi-lg/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Kodi LG – add-on repository</summary>
        <description lang="en_GB">
            Repository for the Kodi LG add-on suite.
            Provides LG remote enhancements including OSD remapping on
            Up/Down during playback and seek-on-release fast forward/rewind.
        </description>
        <platform>all</platform>
        <assets>
            <icon>resources/icon.png</icon>
        </assets>
    </extension>
</addon>
